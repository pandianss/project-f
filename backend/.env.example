# Copy to .env
DATABASE_URL=postgres://farmos:farmos@localhost:5433/farmos
PORT=3001
NODE_ENV=development
# RP threshold to unlock the marketplace Sell capability (see docs/12 §3.1a)
SELL_UNLOCK_THRESHOLD=250
# Auth — set a long random secret in production
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRY=30d
OTP_TTL_MINUTES=5
# CORS — comma-separated allowed origins in production (empty = allow all, dev only)
ALLOWED_ORIGINS=
# Postgres TLS — set true on hosts that require SSL (Render/Supabase). Leave unset
# on Railway/Fly internal DBs and local Docker (they don't support/need TLS).
# DB_SSL=true
